# ── Secrets para deploy no Streamlit Cloud ────────────────────────────────────
#
# 1. Copie este arquivo como referência
# 2. No Streamlit Cloud: Settings → Secrets → cole o conteúdo com seus valores reais
# 3. Nunca commite o arquivo com senhas reais no GitHub
#
# Como obter as URLs do Supabase:
#   Supabase → seu projeto → Settings → Database → Connection string → URI
#   Trocar [YOUR-PASSWORD] pela senha definida no projeto

GLOBAL_DATABASE_URL = "postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres"
BRAZIL_DATABASE_URL = "postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres"
